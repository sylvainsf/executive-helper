# Home Assistant long-lived access token
# (create this in HA after first boot: Profile → Long-Lived Access Tokens)
EH_HA_TOKEN=paste_your_token_here

# Timezone (used by Home Assistant container)
TZ=America/New_York

# EF model name in Ollama (change after loading your fine-tuned model)
EH_EF_MODEL=executive-helper-ef
